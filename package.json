{
  "name": "claw42",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.8.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,md,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,md,json,css}\"",
    "verify:agent-ip": "node scripts/verify-agent-ip.mjs",
    "verify": "npm run typecheck && npm run lint && npm run format:check && npm run build"
  },
  "dependencies": {
    "framer-motion": "^11.18.2",
    "next": "14.2.35",
    "posthog-js": "^1.372.3",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
